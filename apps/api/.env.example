# Copy this file to `.env` and fill in your real connection string.
# `.env` is gitignored — never commit real credentials.
DATABASE_URL=

# Optional: override the API port (defaults to 3004)
# PORT=

# Base URL of the external ATK store API — the users boot roster is fetched
ATK_STORE_API_URL=

# External IoT devices API — the shelfs layout is fetched live from
# {IOT_API_URL}/devices with an `x-iot-api-key` header on every request
IOT_API_URL=
IOT_API_KEY=

MQTT_URL=
MQTT_CONNECT_USE_TLS=
MQTT_USERNAME=
MQTT_PASSWORD=