{
  "name": "atk-store-dashboard",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "dev:web": "bun run --filter '@atk-store-dashboard/web' dev",
    "dev:api": "bun run --filter '@atk-store-dashboard/api' dev",
    "build": "bun run --filter '@atk-store-dashboard/web' build",
    "build:api": "bun run --filter '@atk-store-dashboard/api' build",
    "start:api": "bun run --filter '@atk-store-dashboard/api' start"
  }
}
